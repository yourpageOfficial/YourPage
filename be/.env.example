# App
APP_ENV=development
APP_PORT=8080

# Database
DATABASE_URL=postgres://yourpage:secret@postgres:5432/yourpage?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_PUBLIC_BUCKET=public-media
MINIO_PRIVATE_BUCKET=private-media

# Payment - Xendit
XENDIT_SECRET_KEY=xnd_development_...
XENDIT_WEBHOOK_TOKEN=your-xendit-webhook-token

# Payment - PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# SMTP (Forgot Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourpage.id
SMTP_PASS=your-smtp-password
SMTP_FROM=YourPage <noreply@yourpage.id>

# Platform
PLATFORM_FEE_PERCENT=10
MIN_WITHDRAWAL_IDR=100000
CREDIT_RATE_IDR=1000
MAX_UPLOAD_SIZE_MB=500
FRONTEND_URL=http://localhost:3000
